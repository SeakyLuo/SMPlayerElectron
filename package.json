{
  "name": "smplayer",
  "private": true,
  "version": "3.0.0",
  "description": "Simple Melody Player",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "start": "electron .",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "check:i18n": "node scripts/check-i18n.mjs",
    "audit:i18n": "node scripts/audit-i18n.mjs",
    "preview": "vite preview",
    "test:voice": "node scripts/voice-assistant-parity.mjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win:store": "npm run build && electron-builder --win appx",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@fluentui/react-icons": "^2.0.326",
    "clsx": "^2.1.1",
    "music-metadata": "^11.12.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.seaky.simplemelodyplayer",
    "productName": "简音播放器",
    "copyright": "Copyright © 2026 Seaky",
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*.node"
    ],
    "npmRebuild": true,
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/app-icon.ico",
        "to": "assets/app-icon.ico"
      },
      {
        "from": "public/app-icon.png",
        "to": "assets/app-icon.png"
      }
    ],
    "fileAssociations": [
      {
        "name": "music_player",
        "description": "Simple Melody Player audio file",
        "ext": [
          "mp3",
          "flac",
          "wma",
          "alac",
          "aiff",
          "ape",
          "aac",
          "m4a",
          "wav",
          "ogg",
          "opus"
        ],
        "icon": "public/app-icon.ico",
        "role": "Viewer"
      }
    ],
    "protocols": [
      {
        "name": "Simple Melody Player",
        "schemes": [
          "smplayer"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/app-icon.png"
    },
    "win": {
      "icon": "public/app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "appx": {
      "identityName": "23778SeakyTheLoner.SMPlayer",
      "applicationId": "App",
      "publisher": "CN=CFBE922A-0341-4A7E-B15B-A6DEF6C9E3AF",
      "publisherDisplayName": "SeakyTheLoner",
      "displayName": "Simple Melody Player",
      "backgroundColor": "#F8F8F8",
      "languages": [
        "en-US",
        "zh-CN",
        "fr",
        "ru",
        "ja",
        "de",
        "pt-BR",
        "es",
        "it",
        "zh-Hant",
        "nl",
        "cs",
        "uk",
        "sv",
        "id"
      ],
      "minVersion": "10.0.17763.0",
      "maxVersionTested": "10.0.17763.0",
      "capabilities": [
        "runFullTrust",
        "musicLibrary",
        "removableStorage",
        "backgroundMediaPlayback",
        "internetClient",
        "internetClientServer",
        "privateNetworkClientServer",
        "microphone"
      ]
    },
    "nsis": {
      "oneClick": false,
      "installerIcon": "public/app-icon.ico",
      "uninstallerIcon": "public/app-icon.ico",
      "installerHeaderIcon": "public/app-icon.ico",
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "简音播放器",
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "icon": "public/app-icon.png",
      "category": "AudioVideo",
      "desktop": {
        "entry": {
          "Name": "简音播放器",
          "Comment": "Simple Melody Player"
        }
      },
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "icon": "public/app-icon.ico"
  }
}
